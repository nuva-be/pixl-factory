+fn collect_messages_from(
+    messages: &VecDeque<LocalMessage>,
+    next: u64,
+) -> Result<Vec<LocalMessage>, WorkerControlBusError> {
+    let Some(first_sequence) = messages.front().map(|message| message.sequence) else {
+        return Ok(Vec::new());
+    };
