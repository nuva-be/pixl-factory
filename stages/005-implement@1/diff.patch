+        }
+
+        struct TimingCapture(Arc<Mutex<Option<(u128, u128)>>>);
+
+        #[async_trait]
+        impl RunLifecycle<TestGraph> for TimingCapture {
+            async fn after_node(
+                &self,
+                _node: &TestNode,
+                result: &mut NodeResult,
+                _state: &ExecutionState,
+            ) -> Result<()> {
+                *self.0.lock().unwrap() = Some((
+                    result.inference_time.as_millis(),
