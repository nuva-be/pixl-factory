+    let active_config_path = temp_dir.path().join("settings.toml");
+    let manifest_run_defaults = RunLayer {
+        environment: Some(RunEnvironmentLayer {
+            id: Some(environment_id.to_string()),
+            ..RunEnvironmentLayer::default()
+        }),
+        ..RunLayer::default()
